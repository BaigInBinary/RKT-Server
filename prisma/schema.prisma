// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  accountType UserAccountType @default(ADMIN_PORTAL)
  role      UserRole @default(CASHIER)
  status    UserStatus @default(PENDING)
  permissions String[] @default([])
  favorites Favorite[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  CUSTOMER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserAccountType {
  ADMIN_PORTAL
  LOCAL_USER
}

enum DiscountType {
  FLAT
  PERCENTAGE
  VALUE_BASED
}

enum DiscountScope {
  ALL
  CATEGORY
  SUBCATEGORY
  ITEM
}

enum CollectionSubCategoryMode {
  ALL_ITEMS
  SELECTED_ITEMS
}

model Item {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  slug              String?
  sku               String   @unique
  category          String
  subCategoryId     String?  @db.ObjectId
  subCategory       SubCategory? @relation("ItemSubCategory", fields: [subCategoryId], references: [id])
  imageUrl          String?
  price             Float
  costPrice         Float
  quantity          Int
  minStock          Int
  supplier          String?
  shortDescription  String?
  weightInGrams     Float?
  galleryImages     String[] @default([])
  features          String[] @default([])
  specifications    Json?
  soldCount         Int      @default(0)
  viewerCount       Int      @default(0)
  averageRating     Float    @default(0)
  reviewCount       Int      @default(0)
  reviews           Json?
  variants          Json?
  tags              String[] @default([])
  productType       String?
  vendor            String?
  showOnMainSite    Boolean  @default(true)
  isFreeDelivery    Boolean  @default(false)
  targetedByDiscounts Discount[] @relation("DiscountTargetItem")
  favorites         Favorite[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model DeliveryRateConfig {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  ratePerKg           Float
  minimumCharge       Float
  freeAboveOrderValue Float?
  freeBelowWeightLimit Float?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LeopardsConfig {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  apiKey       String
  apiPassword  String
  originCity   String   @default("4") // Faisalabad
  shipmentType String   @default("1") // 1: Overnight
  baseUrl      String   @default("https://merchantapi.leopardscourier.com/api/")
  isSandbox    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MnpConfig {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  username       String
  password       String
  accountNo      String
  locationId     String   @default("")
  returnLocation String   @default("")
  subAccountId   Int?
  insertType     Int      @default(19)
  service        String   @default("Overnight")
  fragile        String   @default("NO")
  baseUrl        String   @default("https://mnpcourier.com/mycodapi/api/")
  trackingUrl    String   @default("https://tracking.mulphilog.com.pk/api/")
  isSandbox      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ChequeRecord {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  fileName    String
  htmlContent String
  paymentDate String?
  paymentDateValue DateTime?
  chequeNumber String?
  netPayableAmount Float?
  isHtml      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([paymentDateValue])
}

model ShipmentHistory {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingDate          String?
  deliveryDate         String?
  shipperId            Int?
  trackingNumber       String   @unique
  bookedPacketWeight   String?
  arivalDispatchWeight String?
  bookedPacketOrderId  String?
  originCity           String?
  destinationCity      String?
  consignmentNameEng   String?
  consignmentPhone     String?
  consignmentAddress   String?
  bookedPacketStatus   String?
  shipmentType         String?
  codValue             String?
  courierProvider      String?
  rawPayload           Json?
  chequeRef            String?  // Cheque/invoice number from synced cheque report
  chequeDate           String?  // Payment date from synced cheque report
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([bookingDate])
  @@index([bookedPacketStatus])
}


model Category {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String        @unique
  subCategories SubCategory[]
  collectionSelections CollectionCategorySelection[]
  createdAt     DateTime      @default(now())
}

model SubCategory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  categoryId String   @db.ObjectId
  category   Category @relation(fields: [categoryId], references: [id])
  items      Item[]   @relation("ItemSubCategory")
  targetedByDiscounts Discount[] @relation("DiscountTargetSubCategory")
  collectionSelections CollectionSubCategorySelection[]
  createdAt  DateTime @default(now())

  @@unique([name, categoryId])
}

model Discount {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  description          String?
  discountType         DiscountType
  scope                DiscountScope
  discountValue        Float?
  purchaseValueRules   Json?
  minimumPurchaseValue Float         @default(0)
  isActive             Boolean       @default(true)
  startDate            DateTime?
  endDate              DateTime?
  targetCategory       String?
  targetSubCategoryId  String?       @db.ObjectId
  targetSubCategory    SubCategory?  @relation("DiscountTargetSubCategory", fields: [targetSubCategoryId], references: [id])
  targetItemId         String?       @db.ObjectId
  targetItem           Item?         @relation("DiscountTargetItem", fields: [targetItemId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Sale {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  items        SaleItem[]
  subtotal     Float
  tax          Float
  discount     Float
  total        Float
  date         DateTime   @default(now())
  customerName String?
  customerEmail String?
  customerPhone String?
  shippingAddress String?
  city         String?
  postalCode   String?
  paymentMethod String     @default("cod")
  paymentStatus String     @default("pending")
  bankReceiptUrl String?
  bankReceiptPublicId String?
  loanDueDate  DateTime?
  deliveryCharge Float      @default(0)
  txnRefNo     String?    @unique
  trackingNumber String?   
  courierStatus String?     @default("Pending")
  bookingId    String?    
  courierProvider String?
  createdAt    DateTime   @default(now())
}

model ItemSalesHourly {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  itemId      String   @db.ObjectId
  bucketStart DateTime
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([itemId, bucketStart])
  @@index([bucketStart])
}

model Collection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  bannerImage String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories            CollectionCategorySelection[]
  subCategorySelections CollectionSubCategorySelection[]
  directItems           CollectionItemSelection[]
}

model CollectionCategorySelection {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String     @db.ObjectId
  categoryId   String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([collectionId, categoryId])
}

model CollectionSubCategorySelection {
  id            String                    @id @default(auto()) @map("_id") @db.ObjectId
  collectionId  String                    @db.ObjectId
  subCategoryId String                    @db.ObjectId
  mode          CollectionSubCategoryMode @default(ALL_ITEMS)
  collection    Collection                @relation(fields: [collectionId], references: [id])
  subCategory   SubCategory               @relation(fields: [subCategoryId], references: [id])
  selectedItems CollectionSubCategoryItem[]
  createdAt     DateTime                  @default(now())

  @@unique([collectionId, subCategoryId])
}

model CollectionSubCategoryItem {
  id                      String                       @id @default(auto()) @map("_id") @db.ObjectId
  subCategorySelectionId  String                       @db.ObjectId
  itemId                  String                       @db.ObjectId
  subCategorySelection    CollectionSubCategorySelection @relation(fields: [subCategorySelectionId], references: [id])
  createdAt               DateTime                     @default(now())

  @@unique([subCategorySelectionId, itemId])
}

model CollectionItemSelection {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String     @db.ObjectId
  itemId       String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([collectionId, itemId])
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  itemId    String   @db.ObjectId
  item      Item     @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
}

model SitePageContent {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  pageTitle        String
  lastUpdatedLabel String?
  introText        String?
  sections         Json
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

type SaleItem {
  itemId   String
  variantId String?
  variantLabel String?
  image    String?
  name     String
  price    Float
  quantity Int
  total    Float
}
