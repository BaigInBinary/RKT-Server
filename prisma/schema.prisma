// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  accountType UserAccountType @default(ADMIN_PORTAL)
  role      UserRole @default(CASHIER)
  status    UserStatus @default(PENDING)
  permissions String[] @default([])
  favorites Favorite[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserAccountType {
  ADMIN_PORTAL
  LOCAL_USER
}

enum DiscountType {
  FLAT
  PERCENTAGE
  VALUE_BASED
}

enum DiscountScope {
  ALL
  CATEGORY
  SUBCATEGORY
  ITEM
}

enum CollectionSubCategoryMode {
  ALL_ITEMS
  SELECTED_ITEMS
}

model Item {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  sku               String   @unique
  category          String
  subCategoryId     String?  @db.ObjectId
  subCategory       SubCategory? @relation("ItemSubCategory", fields: [subCategoryId], references: [id])
  imageUrl          String?
  price             Float
  costPrice         Float
  quantity          Int
  minStock          Int
  supplier          String?
  shortDescription  String?
  galleryImages     String[] @default([])
  features          String[] @default([])
  specifications    Json?
  soldCount         Int      @default(0)
  viewerCount       Int      @default(0)
  averageRating     Float    @default(0)
  reviewCount       Int      @default(0)
  reviews           Json?
  targetedByDiscounts Discount[] @relation("DiscountTargetItem")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Category {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String        @unique
  subCategories SubCategory[]
  collectionSelections CollectionCategorySelection[]
  createdAt     DateTime      @default(now())
}

model SubCategory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  categoryId String   @db.ObjectId
  category   Category @relation(fields: [categoryId], references: [id])
  items      Item[]   @relation("ItemSubCategory")
  targetedByDiscounts Discount[] @relation("DiscountTargetSubCategory")
  collectionSelections CollectionSubCategorySelection[]
  createdAt  DateTime @default(now())

  @@unique([name, categoryId])
}

model Discount {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  description          String?
  discountType         DiscountType
  scope                DiscountScope
  discountValue        Float?
  purchaseValueRules   Json?
  minimumPurchaseValue Float         @default(0)
  isActive             Boolean       @default(true)
  startDate            DateTime?
  endDate              DateTime?
  targetCategory       String?
  targetSubCategoryId  String?       @db.ObjectId
  targetSubCategory    SubCategory?  @relation("DiscountTargetSubCategory", fields: [targetSubCategoryId], references: [id])
  targetItemId         String?       @db.ObjectId
  targetItem           Item?         @relation("DiscountTargetItem", fields: [targetItemId], references: [id])
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Sale {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  items        SaleItem[]
  subtotal     Float
  tax          Float
  discount     Float
  total        Float
  date         DateTime   @default(now())
  customerName String?
  createdAt    DateTime   @default(now())
}

model ItemSalesHourly {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  itemId      String   @db.ObjectId
  bucketStart DateTime
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([itemId, bucketStart])
  @@index([bucketStart])
}

model Collection {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  bannerImage String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories            CollectionCategorySelection[]
  subCategorySelections CollectionSubCategorySelection[]
  directItems           CollectionItemSelection[]
}

model CollectionCategorySelection {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String     @db.ObjectId
  categoryId   String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([collectionId, categoryId])
}

model CollectionSubCategorySelection {
  id            String                    @id @default(auto()) @map("_id") @db.ObjectId
  collectionId  String                    @db.ObjectId
  subCategoryId String                    @db.ObjectId
  mode          CollectionSubCategoryMode @default(ALL_ITEMS)
  collection    Collection                @relation(fields: [collectionId], references: [id])
  subCategory   SubCategory               @relation(fields: [subCategoryId], references: [id])
  selectedItems CollectionSubCategoryItem[]
  createdAt     DateTime                  @default(now())

  @@unique([collectionId, subCategoryId])
}

model CollectionSubCategoryItem {
  id                      String                       @id @default(auto()) @map("_id") @db.ObjectId
  subCategorySelectionId  String                       @db.ObjectId
  itemId                  String                       @db.ObjectId
  subCategorySelection    CollectionSubCategorySelection @relation(fields: [subCategorySelectionId], references: [id])
  createdAt               DateTime                     @default(now())

  @@unique([subCategorySelectionId, itemId])
}

model CollectionItemSelection {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  collectionId String     @db.ObjectId
  itemId       String     @db.ObjectId
  collection   Collection @relation(fields: [collectionId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([collectionId, itemId])
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  itemId    String
  name      String
  image     String?
  price     Float?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
}

model SitePageContent {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  pageTitle        String
  lastUpdatedLabel String?
  introText        String?
  sections         Json
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

type SaleItem {
  itemId   String
  name     String
  price    Float
  quantity Int
  total    Float
}
