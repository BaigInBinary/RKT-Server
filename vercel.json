{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "src/scripts/extract_excel.py",
        ".python_packages/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js",
      "methods": ["GET", "POST", "PATCH", "DELETE", "OPTIONS", "PUT"]
    }
  ]
}
