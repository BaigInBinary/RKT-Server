{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "packageManager": "pnpm@10.0.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec \"node --import tsx\" src/index.ts",
    "build": "rm -rf dist && prisma generate && tsc -p tsconfig.json --noCheck",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "vercel-build": "rm -rf dist .python_packages && prisma generate && tsc -p tsconfig.json --noCheck && (python3 -m pip install -r requirements.txt -t ./.python_packages || python -m pip install -r requirements.txt -t ./.python_packages)"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.14.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.9",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
