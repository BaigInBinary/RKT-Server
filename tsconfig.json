{
    "ts-node": {
        "files": true
    },
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": false,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "declaration": false,
        "sourceMap": true
    },
    "include": [
        "src/**/*"
, "src/index.ts"    ],
    "exclude": [
        "node_modules",
        "**/*.spec.ts"
    ]
}
